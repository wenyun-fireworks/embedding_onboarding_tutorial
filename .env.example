# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Create a key in the Fireworks dashboard (https://app.fireworks.ai) for your account.
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai

# Local tooling (read as env vars by scripts/; _load_env.sh won't override an
# already-exported value). Uncomment and point at your machine.
# Your clone of the cookbook (https://github.com/fw-ai/cookbook), needed by step 2:
# COOKBOOK_DIR=/path/to/cookbook
# Python interpreter where you installed requirements.txt; scripts default PY to
# python3, so if you used a virtualenv you MUST set this or steps run against the
# wrong interpreter:
# PY=/path/to/venv/bin/python

# Your own Fireworks account id (the part after accounts/ in resource names).
# The trained + embedding models you create land in this account.
FIREWORKS_ACCOUNT_ID=your-account-id

# IDs the tutorial creates in your own account. Change the prefixes to taste.
# Model produced by the trainer (step 3, before re-registering as embedding):
TRAINED_MODEL_ID=qwen3-finetuned-trained
# Embedding model you re-upload and deploy (step 5):
EMBEDDING_MODEL_ID=qwen3-finetuned
DEPLOYMENT_ID=qwen3-finetuned-dep

# Training (step 2). BASE_MODEL is a public TUNABLE base (owned by pyroworks) and
# TRAINING_SHAPE is its matching public validated training shape (owned by
# accounts/fireworks) — usable from any account. See README Step 0 for all three.
# The tokenizer is consistent with the base's vocab (the end-thinking token
# "</think>" is a single token) so the fine-tuned model serves directly.
BASE_MODEL=accounts/pyroworks/models/qwen3-embedding-base-8b
TOKENIZER_MODEL=Qwen/Qwen3-8B
TRAINING_SHAPE=accounts/fireworks/trainingShapes/qwen3-embedding-base-8b/versions/e3oirzs4
EPOCHS=15
BATCH_SIZE=8

# Test (step 6). Baseline for the base-vs-fine-tuned comparison: a strong
# off-the-shelf model that IS served on serverless /v1/embeddings (NOT the
# tunable training BASE_MODEL above, which isn't serverless). Overridable/optional.
# EVAL_BASE_MODEL=accounts/fireworks/models/qwen3-embedding-8b

# Upload (step 4). Max size per output shard when consolidating the checkpoint
# (fewer, larger shards avoid the Alluxio/etcd mount limit at deploy time).
MAX_SHARD_SIZE=5GB

# Deploy (step 5). Self-serve deploy uses the fleet's default serving image (no
# pin needed). Default is B200; you can also use NVIDIA_H200_141GB or
# NVIDIA_H100_80GB. Avoid A100. Availability/quota varies per account — if a
# deploy stays CREATING with RESOURCE_EXHAUSTED or is rejected by a quota cap,
# switch to another GPU and retry (see README Step 5).
ACCELERATOR_TYPE=NVIDIA_B200_180GB
# Optional: pin deployment placement to a same-cloud region (reliable download);
# empty = GLOBAL. Example: us-iowa-1 (GCP, co-located with GCS model artifacts).
REGION=
