# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Create a key in the Fireworks dashboard (https://app.fireworks.ai) for your account.
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai

# Your own Fireworks account id (the part after accounts/ in resource names).
# The trained + embedding models you create land in this account.
FIREWORKS_ACCOUNT_ID=your-account-id

# IDs the tutorial creates in your own account. Change the prefixes to taste.
# Model produced by the trainer (step 2), downloaded in step 3:
TRAINED_MODEL_ID=qwen3-finetuned-trained
# Embedding model you re-upload as Kind=EMBEDDING_MODEL (step 4) and deploy (step 5):
EMBEDDING_MODEL_ID=qwen3-finetuned
# filled in after step 5: firectl list deployments -a $FIREWORKS_ACCOUNT_ID
DEPLOYMENT_ID=

# Training (step 2). BASE_MODEL is a public TUNABLE base (Kind=HF_BASE_MODEL,
# owned by pyroworks) and TRAINING_SHAPE is its matching public validated shape
# (owned by accounts/fireworks) — usable from any account. See README Step 0 for
# all three sizes. The tokenizer is consistent with the base's vocab (the
# end-thinking token "</think>" is a single token) so the model serves cleanly.
BASE_MODEL=accounts/pyroworks/models/qwen3-embedding-8b-ft-base
TOKENIZER_MODEL=Qwen/Qwen3-8B
TRAINING_SHAPE=accounts/fireworks/trainingShapes/qwen3-embedding-base-8b/versions/e3oirzs4
EPOCHS=15
BATCH_SIZE=8

# Deploy (step 5). Embedding DEPLOYMENT SHAPE (validated preset owned by
# accounts/fireworks, named ...-minimal). This routes the model to the embedding
# serving path that appends <|endoftext|> + last-token pooling to match training;
# it also selects the GPU/precision. Pick the shape for your size (README Step 0):
#   0.6B -> accounts/fireworks/deploymentShapes/qwen3-embedding-0p6b-minimal
#   4B   -> accounts/fireworks/deploymentShapes/qwen3-embedding-4b-minimal
#   8B   -> accounts/fireworks/deploymentShapes/qwen3-embedding-8b-minimal
DEPLOYMENT_SHAPE=accounts/fireworks/deploymentShapes/qwen3-embedding-8b-minimal
# Placement: leave REGION empty for GLOBAL (required if your account holds global
# rather than region-scoped GPU quota). Set a same-cloud region (e.g. us-iowa-1,
# co-located with GCS model artifacts) only if you have region-scoped quota.
REGION=

# Test (step 6). Baseline for the base-vs-fine-tuned comparison: a strong
# off-the-shelf model that IS served on serverless /v1/embeddings (NOT the
# tunable training BASE_MODEL above). Overridable/optional.
# EVAL_BASE_MODEL=accounts/fireworks/models/qwen3-embedding-8b

# Local paths the scripts need (or export them instead):
# COOKBOOK_DIR=/path/to/cookbook          # your clone of https://github.com/fw-ai/cookbook (step 2)
# PY=/path/to/venv/bin/python             # the python where you installed the deps
